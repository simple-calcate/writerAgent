{
  "name": "novel-writer",
  "version": "0.2.7-beta.2",
  "description": "网文写作辅助工具 — 文风润色",
  "license": "AGPL-3.0",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && node scripts/obfuscate.js",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "pack": "electron-vite build && node scripts/obfuscate.js && electron-builder --dir",
    "dist": "electron-vite build && node scripts/obfuscate.js && electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "headroom-ai": "^0.22.4",
    "openai": "^4.73.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "javascript-obfuscator": "^5.4.2",
    "postcss": "^8.4.49",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.simple-calcate.novel-writer",
    "productName": "网文写作助手",
    "artifactName": "novel-writer-setup-${version}.${ext}",
    "afterPack": "./scripts/after-pack.js",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "网文写作助手"
    },
    "portable": {
      "artifactName": "novel-writer-portable-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "simple-calcate",
        "repo": "writerAgent"
      }
    ]
  }
}
