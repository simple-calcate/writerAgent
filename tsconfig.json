{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "jsx": "react-jsx",
    "target": "ES2020",
    "lib": ["ES2020"]
  },
  "include": ["src/main/**/*", "src/shared/**/*"],
  "exclude": ["out", "release", "node_modules", ".mimocode"]
}
